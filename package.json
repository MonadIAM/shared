{
  "name": "@monadiam/shared",
  "description": "Shared Kafka/gRPC contracts and common enums between MonadIAM services",
  "author": "Daniil Egorov (https://github.com/Lambdius)",
  "license": "UNLICENSED",
  "version": "1.0.22",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "proto:generate": "mkdir -p src/generated && grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/generated --ts_proto_opt=esModuleInterop=true,forceLong=string,useOptionals=messages,outputEncodeMethods=false,outputJsonMethods=false,outputClientImpl=false -I src/proto src/proto/access_control.proto",
    "build": "npm run proto:generate && tsc && mkdir -p dist/proto && cp src/proto/*.proto dist/proto/",
    "prepare": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint --config ./prettier.config.mjs --fix --format json | node -e \"process.stdin.on('data',d=>JSON.parse(d).forEach(f=>f.output && console.log(f.filePath)));\"",
    "knip": "knip --config configs/knip.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MonadIAM/shared.git"
  },
  "bugs": {
    "url": "https://github.com/MonadIAM/shared/issues"
  },
  "homepage": "https://github.com/MonadIAM/shared#readme",
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@typescript-eslint/parser": "8.46.2",
    "eslint": "9.38.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.4",
    "globals": "16.4.0",
    "grpc-tools": "^1.13.1",
    "knip": "6.15.0",
    "prettier": "3.6.2",
    "ts-proto": "^2.11.8",
    "typescript": "^5.0.0",
    "typescript-eslint": "8.46.2"
  }
}
